# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

DB_URL=jdbc:postgresql://<host>:<port>/<database>
DB_USER=<db_user>
DB_PASSWORD=<db_password>
DB_EMB=false

# JWT configuration. JWT_SECRET must be a long random string in production.
JWT_SECRET=change-me-locally
JWT_ISSUER=dothattask
JWT_AUDIENCE=dothattask-app
JWT_REALM=dothattask
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30

# Firebase Admin SDK for push notifications (optional).
# If not set, notifications become a no-op. Set to absolute path to service_account.json.
FIREBASE_CREDENTIALS_PATH=/path/to/firebase-service-account.json

# Environment: dev, staging, prod
ENV=dev
